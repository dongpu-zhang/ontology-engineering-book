# 智能制造知识管理系统 - 核心本体（OWL Manchester语法）
# Manufacturing KMS - Core Ontology (Manchester Syntax)
#
# 包含：设备类层次、工艺类层次、属性定义、约束公理、SWRL规则注释

Prefix: owl:  <http://www.w3.org/2002/07/owl#>
Prefix: rdfs: <http://www.w3.org/2000/01/rdf-schema#>
Prefix: xsd:  <http://www.w3.org/2001/XMLSchema#>
Prefix: :     <http://example.org/manufacturing#>

Ontology: <http://example.org/manufacturing>
    Annotations:
        rdfs:label "智能制造本体"@zh,
        rdfs:label "Manufacturing Ontology"@en,
        rdfs:comment "智能制造知识管理系统核心本体，覆盖设备、工艺、产品、任务四大模块"@zh

# ==============================
# 顶层类（Top-level Classes）
# ==============================

Class: :Resource
    Annotations:
        rdfs:label "资源"@zh
    SubClassOf: owl:Thing

Class: :Material
    Annotations:
        rdfs:label "材料"@zh
    SubClassOf: owl:Thing

Class: :Tool
    Annotations:
        rdfs:label "刀具"@zh
    SubClassOf: owl:Thing

Class: :Product
    Annotations:
        rdfs:label "产品"@zh
    SubClassOf: owl:Thing

Class: :Task
    Annotations:
        rdfs:label "任务"@zh
    SubClassOf: owl:Thing

Class: :WorkCell
    Annotations:
        rdfs:label "工作单元"@zh
    SubClassOf: owl:Thing

Class: :WorkOrder
    Annotations:
        rdfs:label "工单"@zh
    SubClassOf: owl:Thing

Class: :Conflict
    Annotations:
        rdfs:label "冲突"@zh
    SubClassOf: owl:Thing

Class: :RotationalPart
    Annotations:
        rdfs:label "回转体零件"@zh
    SubClassOf: :Material

Class: :EquipmentCapability
    Annotations:
        rdfs:label "设备能力"@zh
    SubClassOf: owl:Thing

# ==============================
# 设备模块 (Equipment Module) - TBox
# ==============================

Class: :Equipment
    Annotations:
        rdfs:label "设备"@zh
    SubClassOf: :Resource
    DisjointWith: :Material, :Tool

Class: :ProcessingEquipment
    Annotations:
        rdfs:label "加工设备"@zh
    SubClassOf: :Equipment

Class: :CNCMachine
    Annotations:
        rdfs:label "数控机床"@zh
    SubClassOf: :ProcessingEquipment
    SubClassOf: :hasControl value :CNCControl

Class: :Lathe
    Annotations:
        rdfs:label "车床"@zh
    SubClassOf: :CNCMachine
    SubClassOf: :canProcess some :RotationalPart

Class: :MeasurementEquipment
    Annotations:
        rdfs:label "测量设备"@zh
    SubClassOf: :Equipment

Class: :AuxiliaryEquipment
    Annotations:
        rdfs:label "辅助设备"@zh
    SubClassOf: :Equipment

# ==============================
# 设备状态枚举 (Equipment Status Enumeration)
# ==============================

Individual: :Idle
    Annotations: rdfs:label "空闲"@zh

Individual: :Running
    Annotations: rdfs:label "运行中"@zh

Individual: :Maintenance
    Annotations: rdfs:label "维护中"@zh

Individual: :Faulty
    Annotations: rdfs:label "故障"@zh

Individual: :Completed
    Annotations: rdfs:label "已完成"@zh

Individual: :CNCControl
    Annotations: rdfs:label "数控系统"@zh

Class: :EquipmentStatus
    Annotations:
        rdfs:label "设备状态"@zh
    EquivalentTo: { :Idle, :Running, :Maintenance, :Faulty }

# ==============================
# 对象属性 (Object Properties) - RBox
# ==============================

ObjectProperty: :canProcess
    Annotations: rdfs:label "能加工"@zh
    Domain: :Equipment
    Range: :Material

ObjectProperty: :hasCapability
    Annotations: rdfs:label "具有能力"@zh
    Domain: :Equipment
    Range: :EquipmentCapability

ObjectProperty: :hasStatus
    Annotations: rdfs:label "具有状态"@zh
    Domain: :Equipment
    Range: :EquipmentStatus
    Characteristics: Functional

ObjectProperty: :locatedIn
    Annotations: rdfs:label "位于"@zh
    Domain: :Equipment
    Range: :WorkCell

ObjectProperty: :assignedTo
    Annotations: rdfs:label "分配给"@zh
    Domain: :Task
    Range: :Equipment

ObjectProperty: :requiresMaterial
    Annotations: rdfs:label "需要材料"@zh
    Domain: :Task
    Range: :Material

ObjectProperty: :precedes
    Annotations:
        rdfs:label "先于"@zh
        rdfs:comment "工序之间的先后顺序，具有传递性"@zh
    Domain: :Operation
    Range: :Operation
    Characteristics: Transitive

ObjectProperty: :hasControl
    Annotations: rdfs:label "具有控制系统"@zh
    Domain: :CNCMachine
    Range: owl:Thing

ObjectProperty: :hasOperation
    Annotations: rdfs:label "包含工序"@zh
    Domain: :Process
    Range: :Operation

ObjectProperty: :isPartOf
    Annotations: rdfs:label "是...的一部分"@zh
    Domain: :Operation
    Range: :Process

ObjectProperty: :hasMaterial
    Annotations: rdfs:label "具有材料"@zh
    Domain: :Product
    Range: :Material

ObjectProperty: :hasFeature
    Annotations: rdfs:label "具有特征"@zh
    Domain: :Product
    Range: owl:Thing

ObjectProperty: :hasProcess
    Annotations: rdfs:label "具有工艺"@zh
    Domain: :Product
    Range: :Process

ObjectProperty: :recommendedProcess
    Annotations: rdfs:label "推荐工艺"@zh
    Domain: :Product
    Range: :Process

ObjectProperty: :requiresResource
    Annotations: rdfs:label "需要资源"@zh
    Domain: :Task
    Range: :Resource

ObjectProperty: :requiresOperation
    Annotations: rdfs:label "需要工序"@zh
    Domain: :Product
    Range: :Operation

ObjectProperty: :suitableFor
    Annotations: rdfs:label "适合"@zh
    Domain: :EquipmentCapability
    Range: :Operation

# ==============================
# 数据属性 (Data Properties)
# ==============================

DataProperty: :maxDiameter
    Annotations: rdfs:label "最大加工直径(mm)"@zh
    Domain: :Lathe
    Range: xsd:decimal

DataProperty: :power
    Annotations: rdfs:label "功率(kW)"@zh
    Domain: :Equipment
    Range: xsd:decimal

DataProperty: :serialNumber
    Annotations: rdfs:label "序列号"@zh
    Domain: :Equipment
    Range: xsd:string
    Characteristics: Functional

DataProperty: :hasStartTime
    Annotations: rdfs:label "开始时间"@zh
    Domain: :Task
    Range: xsd:dateTime

DataProperty: :hasEndTime
    Annotations: rdfs:label "结束时间"@zh
    Domain: :Task
    Range: xsd:dateTime

DataProperty: :confidence
    Annotations: rdfs:label "置信度"@zh
    Domain: :Process
    Range: xsd:decimal

DataProperty: :hasAvailability
    Annotations: rdfs:label "可用性"@zh
    Domain: :Resource
    Range: xsd:decimal

DataProperty: :price
    Annotations: rdfs:label "价格"@zh
    Domain: :Equipment
    Range: xsd:decimal

# ==============================
# 工艺模块 (Process Module) - TBox
# ==============================

Class: :Process
    Annotations: rdfs:label "加工工艺"@zh
    SubClassOf: owl:Thing

Class: :Operation
    Annotations: rdfs:label "工序"@zh
    SubClassOf: owl:Thing
    SubClassOf: :isPartOf some :Process

Class: :Turning
    Annotations: rdfs:label "车削"@zh
    SubClassOf: :Operation
    SubClassOf: :requires some :Lathe

Class: :Milling
    Annotations: rdfs:label "铣削"@zh
    SubClassOf: :Operation

Class: :Drilling
    Annotations: rdfs:label "钻孔"@zh
    SubClassOf: :Operation

ObjectProperty: :requires
    Annotations: rdfs:label "需要设备"@zh
    Domain: :Operation
    Range: :Equipment

# ==============================
# 冲突类（由SWRL规则推导生成）
# ==============================

Class: :CapabilityConflict
    Annotations: rdfs:label "能力冲突"@zh
    SubClassOf: :Conflict

Class: :StatusConflict
    Annotations: rdfs:label "状态冲突"@zh
    SubClassOf: :Conflict

Class: :TimeConflict
    Annotations: rdfs:label "时间冲突"@zh
    SubClassOf: :Conflict

Class: :ResourceConflict
    Annotations: rdfs:label "资源冲突"@zh
    SubClassOf: :Conflict

Class: :LongMaintenanceWarning
    Annotations: rdfs:label "长时间维护预警"@zh
    SubClassOf: :Conflict

Class: :ParameterWarning
    Annotations: rdfs:label "参数超范围预警"@zh
    SubClassOf: :Conflict

# ==============================
# 描述逻辑约束（DL Axioms）
# ==============================
# 以下约束用自然语言和DL符号表示，需在Protégé中通过OWL表达式输入

# 数控车床必须有数控系统：
# CNCLathe ⊑ ∃hasControl.CNCControl

# 设备利用率在0-1之间：
# Equipment ⊑ ∀hasUtilization.(≥0 ⊓ ≤1.0)

# 正在运行的设备不能同时处于维护状态：
# Running ⊓ Maintenance ⊑ ⊥

# 加工设备至少能加工一种材料：
# ProcessingEquipment ⊑ ∃canProcess.Material

# ==============================
# SWRL调度规则（在Protégé SWRL Tab中输入）
# ==============================

# 规则1：能力冲突检测
# Task(?t) ∧ requiresMaterial(?t, ?m) ∧ assignedTo(?t, ?e) ∧
# Equipment(?e) ∧ ¬canProcess(?e, ?m)
# → CapabilityConflict(?t)

# 规则2：状态冲突检测
# Equipment(?e) ∧ hasStatus(?e, Running) ∧ Task(?t) ∧ assignedTo(?t, ?e)
# → StatusConflict(?t)

# 规则3：时间冲突检测
# Task(?t1) ∧ Task(?t2) ∧ assignedTo(?t1, ?e) ∧ assignedTo(?t2, ?e) ∧
# hasStartTime(?t1, ?s1) ∧ hasEndTime(?t1, ?e1) ∧
# hasStartTime(?t2, ?s2) ∧ hasEndTime(?t2, ?e2) ∧
# swrlb:lessThan(?s1, ?e2) ∧ swrlb:greaterThan(?e1, ?s2)
# → TimeConflict(?t1)

# 规则4：工艺推荐
# Product(?p1) ∧ Product(?p2) ∧
# hasMaterial(?p1, ?m) ∧ hasMaterial(?p2, ?m) ∧
# hasFeature(?p1, ?f) ∧ hasFeature(?p2, ?f) ∧
# hasProcess(?p2, ?proc)
# → recommendedProcess(?p1, ?proc)

# 规则5：工序顺序
# Operation(?op1) ∧ Operation(?op2) ∧
# precedes(?op1, ?op2) ∧ hasStatus(?op1, Completed)
# → canStart(?op2, true)
